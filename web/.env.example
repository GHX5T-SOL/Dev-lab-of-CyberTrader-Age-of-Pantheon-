# ============================================================================
# Dev Lab Website — .env.example
# Copy to .env.local for local dev. On Vercel, set these via `vercel env add`.
# NEVER commit .env / .env.local.
# ============================================================================

# ---- Auth gate -------------------------------------------------------------
# Numeric password for the vault door. Defaults to 2010 if unset (dev only).
DEV_LAB_PASSWORD=2010

# Generated by `node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"`
# Used to sign the session cookie. Rotate if ever exposed.
AUTH_SECRET=

# ---- Cron security ---------------------------------------------------------
# Vercel Cron sends a Bearer token in Authorization header. Generate a random
# string and set this in Vercel env; the cron endpoint validates it.
CRON_SECRET=

# ---- Public site metadata --------------------------------------------------
NEXT_PUBLIC_SITE_NAME="CyberTrader Dev Lab"
NEXT_PUBLIC_PHASE="Phase 0 — Foundation"

# ============================================================================
# AI + media providers
# The Spend dashboard (/office/spend) probes every configured key for live
# balances. Missing keys simply render as "not configured" — nothing breaks.
# ============================================================================

# ---- Primary reasoning -----------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
VERCEL_AI_GATEWAY_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=
HF_TOKEN=
HUGGINGFACE_API_KEY=

# ---- Media generation ------------------------------------------------------
ELEVENLABS_API_KEY=
HEYGEN_API_KEY=
SPRITECOOK_API_KEY=
REMOTION_LICENSE_KEY=

# ---- Infra / services ------------------------------------------------------
CONWAY_API_KEY=
GITHUB_TOKEN=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
SENTRY_DSN=
POSTHOG_API_KEY=

# ---- Data feeds ------------------------------------------------------------
BRAVE_API_KEY=
ZEP_API_KEY=

# ---- On-chain wallets (read-only) ------------------------------------------
# Only the ADDRESS is read in the Spend dashboard (for balance probes).
# NEVER put a PRIVATE_KEY in a web bundle env file.
EVM_WALLET_ADDRESS=
SOLANA_WALLET_ADDRESS=
EVM_RPC_URL=
SOLANA_RPC_URL=
