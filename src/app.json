{
  "expo": {
    "name": "CyberTrader",
    "slug": "cybertrader-age-of-pantheon",
    "scheme": "cybertrader",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0C10",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0B0C10",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ai.cybertrader.app"
    },
    "android": {
      "package": "ai.cybertrader.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B0C10"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "USE_SUPABASE": false,
      "supabaseUrl": "https://your-project.supabase.co",
      "supabaseAnonKey": "your-anon-key"
    }
  }
}
