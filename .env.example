# ============================================================================
# CyberTrader: Age of Pantheon — .env.example
# ----------------------------------------------------------------------------
# Copy to `.env` and fill in real values. NEVER commit .env.
# Browser auth note: some tools (ElizaOS Discord/Telegram bridges, Solana
# wallet adapter, Supabase Auth) open a browser window for OAuth. Use a
# desktop environment, not headless, the first time.
# ============================================================================

# ---- Supabase (Backend) -----------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-side only, never ship to client
SUPABASE_PROJECT_REF=

# ---- Solana (Web3) ----------------------------------------------------------
# Phase 1 is feature-flagged behind dev identity; fill these when you turn on
# real wallet auth in Phase 2+.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_CLUSTER=mainnet-beta
OBOL_TOKEN_MINT=            # $OBOL SPL mint (leave blank until minted)

# ---- Expo / EAS -------------------------------------------------------------
EXPO_PUBLIC_APP_NAME=CyberTrader
EXPO_PUBLIC_API_BASE_URL=
EAS_PROJECT_ID=

# ---- AI Agent frameworks ----------------------------------------------------
# ElizaOS (multi-agent market simulation swarm)
ELIZA_OPENAI_API_KEY=
ELIZA_ANTHROPIC_API_KEY=
ELIZA_DISCORD_TOKEN=        # optional, if you wire up Discord comms
ELIZA_TELEGRAM_TOKEN=       # optional

# OpenClaw (repo-embedded executor)
OPENCLAW_API_KEY=

# CatchMe (agent context memory)
CATCHME_DATA_DIR=./.catchme/data

# SpriteCook (asset generation) — MCP handles auth, no env var needed unless
# you call the raw HTTP API directly
SPRITECOOK_API_KEY=         # only needed for direct HTTP asset import

# ---- Remotion / HeyGen Hyperframes (cinematics) -----------------------------
REMOTION_LICENSE_KEY=       # required for commercial use
HEYGEN_API_KEY=

# ---- Observability & analytics (Phase 2+) -----------------------------------
SENTRY_DSN=
POSTHOG_API_KEY=

# ---- Development flags ------------------------------------------------------
NODE_ENV=development
FEATURE_FLAG_TERRITORY=false
FEATURE_FLAG_CREW_WARS=false
FEATURE_FLAG_OBOL_ONCHAIN=false
DEV_IDENTITY_ENABLED=true   # Phase 1: always true
