# ============================================================================
# CyberTrader: Age of Pantheon — .gitignore
# ============================================================================

# Node / JS
node_modules/
.pnpm-store/
.yarn/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env & secrets
.env
.env.local
.env.*.local
.env.development
.env.production
*.pem
*.key
secrets/

# Expo / React Native
.expo/
.expo-shared/
dist/
web-build/
*.jks
*.p8
*.p12
*.mobileprovision
*.orig.*
android/
ios/
!docs/ios/
!docs/android/

# Build outputs
build/
out/
coverage/
.next/
.nuxt/
.turbo/
.vercel/

# TypeScript
*.tsbuildinfo

# Editors / OS
.DS_Store
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
Thumbs.db

# Supabase local
.supabase/
supabase/.branches
supabase/.temp

# AI agent caches (keep configs, not runtime state)
.elizaos/runtime/
.openclaw/cache/
.catchme/data/
.claude/local-runtime/

# Playground scratch — keep the directory, ignore ad-hoc experiments
playground/*
!playground/README.md
!playground/.gitkeep

# Misc
*.tmp
*.cache
.superdesign

# SSH keys
.ssh/

